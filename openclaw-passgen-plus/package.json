{
  "name": "@brucestudios/passgen-plus",
  "version": "1.0.0",
  "description": "An advanced CLI tool for generating secure, customizable passwords with multiple entropy sources and validation features",
  "main": "dist/index.js",
  "bin": {
    "passgen-plus": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "test": "jest",
    "docs": "typedoc --out docs src",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts",
    "release": "standard-version && git push --follow-tags origin main && npm publish"
  },
  "keywords": [
    "password",
    "generator",
    "security",
    "cli",
    "entropy",
    "passgen"
  ],
  "author": "Bruce Studios <bruce@brucestudios.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brucestudios/openclaw-passgen-plus.git"
  },
  "bugs": {
    "url": "https://github.com/brucestudios/openclaw-passgen-plus/issues"
  },
  "homepage": "https://github.com/brucestudios/openclaw-passgen-plus#readme",
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "standard-version": "^9.0.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.0.0",
    "typedoc": "^0.25.0",
    "typescript": "^5.0.0",
    "webpack": "^5.0.0",
    "webpack-cli": "^5.0.0"
  },
  "dependencies": {
    "chalk": "^5.0.0",
    "commander": "^11.0.0",
    "qrcode-terminal": "^0.12.0"
  }
}